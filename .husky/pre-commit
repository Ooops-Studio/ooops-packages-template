#!/usr/bin/env sh
set -eu

# Fast-fail if every staged file is documentation
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -n "$STAGED_FILES" ] && printf '%s\n' "$STAGED_FILES" | grep -Eqv '^(docs/|.+\.md)$'; then
  :
elif [ -n "$STAGED_FILES" ]; then
  echo "Docs-only changes: running lint only"
  pnpm -w lint
  exit 0
fi

pnpm -w lint
pnpm -w typecheck
# Don’t run tests here; your CI handles the heavy lifting
