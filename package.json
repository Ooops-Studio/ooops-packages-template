{
	"name": "@<your-scope>/<name>",
	"version": "0.0.0",
	"description": "TypeScript + pnpm packages monorepo template with Vitest, ESLint (flat), tsup, Husky/Commitlint, Changesets, dependency-cruiser, publint, ATTW, size-limit, and GitHub Actions CI — strict, fast, and ready to publish.",
	"private": true,
	"type": "module",
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.20.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Ooops-Studio/repo-name.git"
	},
	"scripts": {
		"typecheck": "pnpm -r --filter './packages/*' run typecheck",
		"lint": "eslint --cache --cache-strategy content --cache-location .cache/eslint --no-error-on-unmatched-pattern .dependency-cruiser.cjs commitlint.config.mjs eslint.config.js vitest.config.ts \"scripts/**/*.{js,mjs,cjs,ts,tsx}\" \"examples/**/*.{js,mjs,cjs,ts,tsx}\" \"packages/*/*.{js,mjs,cjs,ts,tsx}\" \"packages/*/{src,test}/**/*.{js,mjs,cjs,ts,tsx}\"",
		"test": "pnpm -r --filter './packages/*' --if-present run test",
		"build": "pnpm -r --filter './packages/*' run build",
		"size": "pnpm -r --filter './packages/*' --if-present run size",
		"depcruise": "depcruise --config .dependency-cruiser.cjs packages/**/src",
		"publint": "pnpm -r --filter './packages/*' --if-present run publint",
		"attw": "pnpm -r --filter './packages/*' --if-present run attw",
		"bootstrap": "node ./scripts/setup-template.mjs",
		"init:template": "node ./scripts/init-template.mjs",
		"setup:module": "node ./scripts/setup-module.mjs",
		"guard:template": "node ./scripts/template-guard.mjs",
		"check:manifests": "node ./scripts/check-package-manifests.mjs",
		"check:optional-modules": "node ./scripts/check-optional-modules.mjs",
		"check:workflows": "node ./scripts/check-workflows.mjs",
		"check:agents": "node ./scripts/check-agents.mjs",
		"check:organization-policy": "node ./scripts/check-organization-policy.mjs",
		"check:packed-artifacts": "node ./scripts/check-packed-artifacts.mjs",
		"test:installer-policies": "node ./scripts/test-installer-policies.mjs",
		"readiness": "node ./scripts/package-readiness.mjs",
		"readiness:json": "node ./scripts/package-readiness.mjs --json",
		"readiness:strict": "node ./scripts/package-readiness.mjs --strict",
		"check:licenses": "node ./scripts/check-licenses.mjs",
		"smoke:archetypes": "node ./scripts/smoke-check-archetypes.mjs",
		"smoke:package-tools": "node ./scripts/smoke-check-package-tools.mjs",
		"audit:prod": "pnpm audit --prod --audit-level moderate",
		"audit:dev": "pnpm audit --dev --audit-level moderate",
		"release:preflight": "node ./scripts/release-preflight.mjs",
		"publish:packages": "node ./scripts/publish-packages.mjs",
		"create:package": "node ./scripts/create-package.mjs",
		"copy:package": "node ./scripts/copy-package-from-repo.mjs",
		"deprecate:package": "node ./scripts/deprecate-package.mjs",
		"changeset": "changeset",
		"validate:ci": "node ./scripts/validate-ci.mjs",
		"validate": "pnpm guard:template && pnpm check:manifests && pnpm check:optional-modules && pnpm check:workflows && pnpm check:agents && pnpm check:licenses && pnpm test:installer-policies && pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm size && pnpm depcruise && pnpm publint && pnpm attw && pnpm check:packed-artifacts && pnpm readiness && pnpm smoke:package-tools",
		"prepare": "husky"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@changesets/changelog-github": "^0.5.1",
		"@changesets/cli": "^2.28.0",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@eslint/js": "^9.39.1",
		"@size-limit/preset-small-lib": "^11.2.0",
		"@stylistic/eslint-plugin": "^5.4.0",
		"@types/node": "^20.12.12",
		"@typescript-eslint/eslint-plugin": "^8.45.0",
		"@typescript-eslint/parser": "^8.45.0",
		"@vitest/coverage-v8": "^3.2.4",
		"dependency-cruiser": "^17.0.1",
		"eslint": "^9.37.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.31.0",
		"globals": "^16.4.0",
		"husky": "^9.1.7",
		"publint": "^0.3.13",
		"size-limit": "^11.2.0",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
