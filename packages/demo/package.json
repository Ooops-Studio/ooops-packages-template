{
  "name": "@<your-scope>/<name>",
  "description": "Simple public single-entry package archetype example.",
  "version": "0.0.0",
  "type": "module",
  "publishConfig": {"access": "public"},
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ooops-Studio/repo-name.git"
  },
  "homepage": "https://github.com/Ooops-Studio/repo-name",
  "bugs": {
    "url": "https://github.com/Ooops-Studio/repo-name/issues"
  },
	"engines": {"node": ">=20"},
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsup",
    "depcruise": "depcruise --no-config src",
    "size": "size-limit --config .size-limit.json",
    "publint": "publint",
    "attw": "attw --pack --ignore-rules no-resolution --ignore-rules cjs-resolves-to-esm"
  }
}
