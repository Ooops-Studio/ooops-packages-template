{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended"
	],
	"timezone": "Europe/Athens",
	"schedule": [
		"before 9am on monday"
	],
	"automerge": false,
	"dependencyDashboard": true,
	"labels": [
		"dependencies"
	],
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": [
			"before 9am on monday"
		]
	},
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": ["/scripts/action-references\\.mjs$/"],
			"matchStrings": ["'(?<depName>[^']+)': \\{\\s*version: '(?<currentValue>v[^']+)',\\s*sha: '(?<currentDigest>[a-f0-9]{40})'"],
			"datasourceTemplate": "github-tags"
		}
	],
	"packageRules": [
		{
			"matchManagers": [
				"github-actions"
			],
			"groupName": "github actions",
			"labels": [
				"dependencies",
				"github-actions"
			]
		},
		{
			"matchDepTypes": [
				"devDependencies"
			],
			"groupName": "dev tooling",
			"labels": [
				"dependencies",
				"tooling"
			]
		},
		{
			"matchPackageNames": [
				"/^@?eslint/",
				"/^@typescript-eslint/",
				"/^vitest/",
				"/^@vitest/",
				"typescript",
				"tsup",
				"size-limit",
				"publint",
				"dependency-cruiser",
				"@arethetypeswrong/cli"
			],
			"groupName": "lint test build tools",
			"labels": [
				"dependencies",
				"tooling"
			]
		}
	]
}
